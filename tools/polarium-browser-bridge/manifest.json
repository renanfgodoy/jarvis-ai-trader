{
  "manifest_version": 3,
  "name": "J.A.R.V.I.S Polarium Bridge",
  "version": "0.20.0",
  "description": "Read-only local bridge for forwarding Polarium WebSocket account/market events to J.A.R.V.I.S running on localhost.",
  "permissions": [],
  "action": {
    "default_title": "Friday Trade Polarium Bridge"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://trade.polariumbroker.com/*",
    "https://*.polariumbroker.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://trade.polariumbroker.com/*", "https://*.polariumbroker.com/*"],
      "js": ["page-bridge-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://trade.polariumbroker.com/*", "https://*.polariumbroker.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge-main.js"],
      "matches": ["https://trade.polariumbroker.com/*", "https://*.polariumbroker.com/*"]
    }
  ]
}
