# J.A.R.V.I.S AI TRADER — configuração local
APP_NAME="J.A.R.V.I.S AI TRADER"
APP_VERSION="0.24.0"
ENVIRONMENT="development"
API_PREFIX="/api/v1"

# Gestão de risco
BANKROLL_BASE=200
RISK_PERCENTAGE=5
MAX_DAILY_WINS=3
MAX_DAILY_LOSSES=2
MAX_GALE_ALLOWED=1
MINIMUM_PAYOUT=75

# Mercado
DEFAULT_MARKET_PROVIDER="simulated"
DEFAULT_SYMBOL="EURUSD-OTC"
DEFAULT_TIMEFRAME="M1"

# Polarium OAuth/PKCE — use somente credenciais próprias e autorizadas
POLARIUM_OAUTH_CLIENT_ID=
POLARIUM_OAUTH_AUTHORIZE_URL=https://api.trade.polariumbroker.com/auth/oauth.v5/authorize
POLARIUM_OAUTH_TOKEN_URL=https://api.trade.polariumbroker.com/auth/oauth.v5/token
POLARIUM_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/v1/polarium/oauth/callback
POLARIUM_OAUTH_SCOPE="full offline_access"
POLARIUM_WS_URL=wss://ws.trade.polariumbroker.com/echo/websocket
